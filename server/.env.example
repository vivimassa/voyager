# ---- Voyager server environment ----
# Copy to `.env` for local dev. On Render, paste these in the service's
# Environment tab. NEVER commit real values.

# MongoDB Atlas connection string (see DEPLOY.md for how to create one)
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/voyager?retryWrites=true&w=majority

# Minimum 32 chars. Generate a random one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional: defaults are usually fine
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Render injects PORT automatically; only override locally.
PORT=3002

NODE_ENV=development

# In production, restrict to your Vercel URL, e.g. https://voyager.vercel.app
# Locally, "*" is fine.
CORS_ORIGIN=*

# Public URL of the web app (used to build links in emails/SMS).
CLIENT_URL=http://localhost:3000

# ---- SMS / OTP (optional for demo) ----
# Default "console" prints OTPs to server logs — fine for a demo.
SMS_PROVIDER=console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Branding used in OTP SMS body
BRAND_NAME=Voyager
